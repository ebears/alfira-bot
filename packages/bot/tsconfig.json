{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "lib": ["ES2020"],
    "outDir": "./dist",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "paths": {
      "@alfira-bot/shared/prisma": ["./node_modules/@alfira-bot/shared/dist/lib/prisma"]
    }
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist"]
}
