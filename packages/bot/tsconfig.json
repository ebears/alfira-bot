{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "moduleResolution": "node",
    "baseUrl": ".",
    "paths": {
      "@alfira-bot/shared": ["./node_modules/@alfira-bot/shared/dist/"],
      "@alfira-bot/shared/db": ["./node_modules/@alfira-bot/shared/dist/db/index.d.ts"],
      "@alfira-bot/shared/logger": ["./node_modules/@alfira-bot/shared/dist/logger.d.ts"]
    },
    "lib": ["ES2020"],
    "outDir": "./dist",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "ignoreDeprecations": "6.0"
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist"]
}
