{
  "name": "@alfira-bot/server",
  "version": "0.1.0",
  "private": true,
  "main": "./dist/index.js",
  "exports": {
    ".": "./dist/index.js",
    "./shared": "./dist/shared/index.js",
    "./shared/*": "./dist/shared/*"
  },
  "scripts": {
    "dev": "bun run src/index.ts",
    "build": "tsc --skipLibCheck",
    "db:generate": "cd ../.. && drizzle-kit generate",
    "db:migrate": "cd ../.. && drizzle-kit migrate",
    "db:migrate:deploy": "cd ../.. && drizzle-kit migrate",
    "db:studio": "cd ../.. && drizzle-kit studio"
  },
  "dependencies": {
    "cookie": "^1.1.1",
    "dotenv": "^17.3.1",
    "drizzle-orm": "^0.45.2",
    "hoshimi": "^0.3.9",
    "jsonwebtoken": "^9.0.3",
    "pino": "^10.0.0",
    "seyfert": "^4.3.0"
  },
  "devDependencies": {
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.4.0",
    "bun-types": "^1.3.11",
    "typescript": "^6.0.0"
  }
}
