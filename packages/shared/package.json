{
  "name": "@alfira-bot/shared",
  "version": "0.1.0",
  "private": true,
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "source": "./src/index.ts",
      "default": "./dist/index.js"
    },
    "./api": {
      "types": "./dist/api.d.ts",
      "source": "./src/api.ts",
      "default": "./dist/api.js"
    },
    "./format": {
      "types": "./dist/format.d.ts",
      "source": "./src/format.ts",
      "default": "./dist/format.js"
    },
    "./logger": {
      "types": "./dist/logger.d.ts",
      "source": "./src/logger.ts",
      "default": "./dist/logger.js"
    },
    "./db": {
      "types": "./dist/db/index.d.ts",
      "source": "./src/db/index.ts",
      "default": "./dist/db/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "db:generate": "cd ../.. && drizzle-kit generate",
    "db:migrate": "cd ../.. && drizzle-kit migrate",
    "db:migrate:deploy": "cd ../.. && drizzle-kit migrate",
    "db:studio": "cd ../.. && drizzle-kit studio"
  },
  "dependencies": {
    "drizzle-orm": "^0.45.2",
    "pino": "^10.3.1",
    "postgres": "^3.4.9"
  },
  "devDependencies": {
    "drizzle-kit": "^0.31.10",
    "typescript": "5.9.3"
  }
}
