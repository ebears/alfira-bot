{
  "name": "@alfira-bot/shared",
  "version": "0.1.0",
  "private": true,
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "source": "./src/index.ts",
      "default": "./dist/index.js"
    },
    "./api": {
      "types": "./dist/api.d.ts",
      "source": "./src/api.ts",
      "default": "./dist/api.js"
    },
    "./format": {
      "types": "./dist/format.d.ts",
      "source": "./src/format.ts",
      "default": "./dist/format.js"
    },
    "./prisma": {
      "types": "./dist/lib/prisma.d.ts",
      "source": "./src/lib/prisma.ts",
      "default": "./dist/lib/prisma.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:studio": "prisma studio"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.6.0",
    "@prisma/client": "^7.6.0",
    "pino": "^10.3.1"
  },
  "devDependencies": {
    "prisma": "^7.6.0",
    "typescript": "^5.4.5"
  }
}
