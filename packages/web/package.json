{
  "name": "@alfira-bot/web",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun run src/server.ts",
    "build:css": "echo 'No CSS to build'",
    "build": "tsc && bun build ./src/main.tsx --outdir=./dist --minify && cp ./index.html ./dist/ && sed -i 's|/src/main.tsx|/main.js|g' ./dist/index.html && sed -i 's|/src/index.css|/index.css|g' ./dist/index.html && cp -r ./public/* ./dist/"
  },
  "dependencies": {
    "@alfira-bot/shared": "workspace:*",
    "@phosphor-icons/react": "^2.1.10",
    "@tanstack/react-virtual": "^3.13.23",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router-dom": "^7.13.2"
  },
  "devDependencies": {
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "bun-types": "^1.3.11",
    "typescript": "^5.4.5"
  }
}
