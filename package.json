{
  "name": "discord-music-bot",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run -w packages/api dev",
    "web:dev": "npm run -w packages/web dev",
    "bot:deploy": "npm run -w packages/bot deploy",
    "db:migrate": "npm run -w packages/api db:migrate",
    "db:generate": "npm run -w packages/api db:generate",
    "db:studio": "npm run -w packages/api db:studio",
    "lint": "biome lint .",
    "lint:fix": "biome lint --write .",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "check": "biome check --write ."
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.6"
  },
  "overrides": {
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  }
}
