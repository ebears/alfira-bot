{
  "name": "alfira-bot",
  "private": true,
  "packageManager": "bun@1.3.11",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "bun run --filter @alfira-bot/shared build && bun run --filter @alfira-bot/bot build && docker compose up --build",
    "web:build": "bun run --filter @alfira-bot/web build",
    "bot:deploy": "bun run --filter @alfira-bot/bot deploy",
    "db:migrate": "bun run --filter @alfira-bot/shared db:migrate",
    "db:generate": "bun run --filter @alfira-bot/shared db:generate",
    "db:studio": "bun run --filter @alfira-bot/shared db:studio",
    "lint": "biome lint .",
    "lint:fix": "biome lint --write .",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "check": "biome check --write ."
  },
  "overrides": {
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "serialize-javascript": "7.0.4",
    "undici": "6.24.0",
    "lodash": "4.17.23"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.9",
    "@types/node": "^22.0.0",
    "typescript": "^6.0.0"
  }
}
